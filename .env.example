NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=your-secret-key
GEMINI_API_KEY=
GEMINI_FALLBACK_MODEL=gemini-3.5-flash-lite
GOOGLE_MAPS_API_KEY=
CRON_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Bundled iOS client. Use the deployed HTTPS origin in release builds.
VITE_KAIROS_API_URL=http://localhost:3000
# Mobile rollout flags. Set a capability to 0 to hold that phase back.
VITE_KAIROS_NATIVE_SPEECH=1
VITE_KAIROS_APPLE_PLANNER=1
VITE_KAIROS_OFFLINE_SYNC=1
VITE_KAIROS_GEMINI_FALLBACK=1
# Set to 1 only to deploy the seeded preview intentionally; otherwise an unconfigured deployment returns 503.
KAIROS_ALLOW_PREVIEW=
